# Backend API base URL. NEXT_PUBLIC_ prefix is required: the admin dashboard
# calls this from the browser. Set to your deployed backend origin in production.
NEXT_PUBLIC_BACKOFFICE_URL="http://localhost:5000"

NEXTAUTH_URL=http://localhost:3001
# Required in production (used to sign/verify the session JWT). Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Shared secret for the /api/revalidate endpoint the backend calls to trigger
# revalidateTag (content edits + hourly greeting cron). MUST be identical to the
# value configured on the backend. Server-only — never expose to the browser.
REVALIDATE_SECRET=
